{
    "compilerOptions": {
        // ── Language ──────────────────────────────────────────
        "lib": ["ESNext"],
        "target": "ESNext",

        // ── Module ────────────────────────────────────────────
        "allowImportingTsExtensions": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,

        // ── Interop ───────────────────────────────────────────
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,

        // ── Strictness ────────────────────────────────────────
        "skipLibCheck": true,
        "strict": true,

        // ── Output ────────────────────────────────────────────
        "noEmit": true,

        // ── Paths ─────────────────────────────────────────────
        "paths": { "@/*": ["./src/*"] }
    },
    "exclude": ["node_modules"],
    "include": ["src/**/*.ts"]
}
